%%{ init: { 'theme': 'base', 'themeVariables': { 'fontSize': '14px' } } }%%
graph TB
    subgraph UI["用户界面层"]
        direction LR
        subgraph S1["学生端 (Vue 3 + Vite)"]
            S1A["知识检索 · 图谱浏览<br/>问答对话 · SSE流式输出<br/>题目练习 · 学习分析"]
        end
        subgraph S2["教师/管理员端 (Vue 3 + Vite)"]
            S2A["文档审核 · 知识点管理<br/>题库管理 · 学生管理<br/>系统概览 · 学情监控"]
        end
    end

    subgraph Backend["后端网关层 (Go + Gin)"]
        direction LR
        B1["路由与网关包<br/>API路由 · 请求分发"]
        B2["认证授权包<br/>JWT认证 · RBAC授权<br/>学生/教师双认证"]
        B3["业务服务包<br/>问答引擎 · 图谱构建<br/>文档管理 · 学习分析"]
        B4["数据访问包<br/>GORM ORM · 事务管理<br/>双写策略"]
        B5["通用组件包<br/>日志 · 配置 · 异常处理<br/>统一响应 · 密码加密"]
        B6["对外服务包<br/>Ollama客户端<br/>MinIO存储客户端"]
    end

    subgraph AI["AI服务层 (Go - Ollama Client)"]
        direction LR
        A1["文档解析包<br/>多格式文本提取<br/>文本分块"]
        A2["知识抽取包<br/>LLM实体/关系抽取<br/>正则回退 · 本体校验"]
        A3["向量处理包<br/>Embedding生成<br/>余弦相似度检索"]
        A4["问答推理包<br/>5级降级策略<br/>混合检索 · 图增强RAG<br/>SSE流式生成"]
        A5["评测分析包<br/>学习统计 · 掌握度评估<br/>薄弱点分析"]
        A6["AI调度中心<br/>统一AI入口 · 服务编排<br/>Ollama HTTP客户端"]
    end

    subgraph Data["数据与基础设施层"]
        direction LR
        D1[("图数据库<br/>Neo4j<br/>KnowledgePoint节点<br/>RELATED/DEPENDS_ON/PART_OF边")]
        D2[("向量存储<br/>内存 + JSON<br/>768维 · 余弦相似度")]
        D3[("关系数据库<br/>MySQL<br/>10张表 · GORM迁移")]
        D4[("对象存储<br/>MinIO<br/>文件上传/下载")]
    end

    S1 -->|"HTTP/HTTPS (JSON)"| B1
    S2 -->|"HTTP/HTTPS (JSON)"| B1
    B1 --> B2
    B1 --> B3
    B3 --> B4
    B3 --> B6
    B2 --> B5
    B6 -->|"HTTP调用"| A6
    A6 --> A1
    A6 --> A2
    A6 --> A3
    A6 --> A4
    A6 --> A5
    A4 -.->|"读写"| D1
    A3 -.->|"读写"| D2
    B4 -->|"GORM读写"| D3
    B6 -.->|"对象存储"| D4
    A4 -.->|"返回结果(JSON)"| B3

